{
  "name": "@scion/web-frontend",
  "version": "0.1.0",
  "description": "Scion Web Frontend - Browser-based dashboard for managing agents and groves",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rm -rf node_modules dist public/assets",
    "dev": "tsx watch --clear-screen=false src/server/index.ts",
    "dev:client": "vite --mode development",
    "dev:full": "npm run build:client:dev && npm run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build && npm run copy:client",
    "build:client:dev": "vite build --mode development && npm run copy:client",
    "copy:client": "mkdir -p public/assets && cp -r dist/client/assets/* public/assets/",
    "start": "node dist/server/server/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^13.0.0",
    "@lit-labs/ssr": "^3.2.2",
    "@lit-labs/ssr-client": "^1.1.7",
    "@shoelace-style/shoelace": "^2.19.0",
    "@vaadin/router": "^1.7.5",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "koa": "^3.1.0",
    "koa-bodyparser": "^4.4.1",
    "koa-session": "^7.0.2",
    "koa-static": "^5.0.0",
    "lit": "^3.1.2",
    "nats": "^2.28.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/koa": "^3.0.0",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-session": "^6.4.5",
    "@types/koa-static": "^4.0.4",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
